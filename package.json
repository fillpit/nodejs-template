{
  "name": "node-template",
  "version": "1.0.0",
  "description": "Standard Full-Stack Project Template",
  "author": "Antigravity",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "run-p dev:*",
    "dev:backend": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true && sleep 1 && pnpm -C backend dev",
    "dev:frontend": "pnpm -C frontend dev",
    "init-project": "node scripts/init.mjs",
    "build:all": "run-s build:backend build:frontend",
    "build:backend": "pnpm -C backend build",
    "build:frontend": "pnpm -C frontend build",
    "install:all": "run-s install:backend install:frontend",
    "install:backend": "pnpm -C backend install",
    "install:frontend": "pnpm -C frontend install",
    "electron:dev": "run-s build:all && electron .",
    "electron:build": "run-s build:all && electron-builder --config electron/builder.config.js"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^8.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "npm-run-all2": "^8.0.4",
    "prompts": "^2.4.2",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1"
  }
}