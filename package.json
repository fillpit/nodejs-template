{
  "name": "node-template",
  "version": "1.0.0",
  "description": "Standard Full-Stack Project Template",
  "author": "Antigravity",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter node-template-backend dev",
    "dev:frontend": "pnpm --filter node-template-frontend dev",
    "init-project": "node scripts/init.mjs",
    "build:all": "pnpm -r build",
    "build:backend": "pnpm --filter node-template-backend build",
    "build:frontend": "pnpm --filter node-template-frontend build",
    "install:all": "pnpm install",
    "electron:dev": "pnpm build:all && electron .",
    "electron:build": "pnpm build:all && electron-builder --config electron/builder.config.js",
    "lint": "eslint . --cache --cache-location .cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-location .cache/eslint/"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^8.2.0",
    "@eslint/js": "^9.39.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "prompts": "^2.4.2",
    "typescript-eslint": "^8.59.1"
  }
}