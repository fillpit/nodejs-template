{
  "name": "node-template-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && rm -rf dist/generated && (test -d src/generated && cp -r src/generated dist/generated || true)",
    "start": "node dist/index.js",
    "lint": "eslint . --cache --cache-location ../.cache/eslint/backend/",
    "lint:fix": "eslint . --fix --cache --cache-location ../.cache/eslint/backend/"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "hono": "^4.6.15",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}